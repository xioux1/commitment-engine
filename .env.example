NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/commitment_engine

# Discriminador API
DISCRIMINADOR_BASE_URL=http://localhost:3000
DISCRIMINADOR_API_KEY=

# IMPORTANT: Keep DRY_RUN=true for at least 2 weeks before connecting real funds.
# In dry-run mode, all wallet_actions are logged but never executed.
DRY_RUN=true

# Cron schedule (default: every Monday at 08:00)
# Syntax: second minute hour day-of-month month day-of-week
CRON_SCHEDULE=0 8 * * 1

LOG_LEVEL=info

# ── Stage 2 — Smart Contract ──────────────────────────────────────────────────
# Deploy CommitmentVault.sol first (cd contracts && npm run deploy:sepolia),
# then fill these in.

# Address of the deployed CommitmentVault contract
COMMITMENT_VAULT_ADDRESS=

# Private key of the deployer/owner wallet.
# NEVER commit this. NEVER share this. Store in a secrets manager for prod.
EXECUTOR_PRIVATE_KEY=

# Base RPC endpoints
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# USDC token address (Base mainnet; change for testnet)
# Mainnet:  0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Sepolia:  0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Basescan API key for contract verification
BASESCAN_API_KEY=
